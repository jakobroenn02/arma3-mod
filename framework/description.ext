// description.ext — STCTI vertical slice. See §G4.
author = "Jakob";
onLoadName = "STCTI — Vertical Slice";
onLoadMission = "Capture. Earn. Spend. Defend.";
overviewText = "Strategic CTI — Phase 1 vertical slice (Altis).";

// Conventional reinforcement: respawn at the base ("respawn_west" marker placed by
// fn_serverPlaceBase), debiting manpower (fn_serverRespawnCost via the CBA unit handler).
respawn = "BASE";
respawnDelay = 15;
respawnOnStart = -1;
disabledAI = 1;
joinUnassigned = 0;

class Header {
    gameType = "Coop";
    minPlayers = 1;
    maxPlayers = 4;
};

